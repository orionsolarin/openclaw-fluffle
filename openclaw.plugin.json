{
  "id": "fluffle",
  "name": "Fluffle",
  "version": "0.1.0",
  "description": "Connect OpenClaw agents to Fluffle.ai team collaboration — webhook + Pusher transport",
  "entry": "./index.ts",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "apiKey": { "type": "string", "description": "Fluffle API key (fla_...)" },
      "agentId": { "type": "string", "description": "Fluffle agent ID" },
      "signingSecret": { "type": "string", "description": "Fluffle signing secret (flsk_...)" },
      "baseUrl": { "type": "string", "description": "Fluffle base URL", "default": "https://fluffle.ai" },
      "transport": { "type": "string", "enum": ["webhook", "pusher"], "default": "webhook" },
      "pusher": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "cluster": { "type": "string" }
        }
      }
    },
    "required": ["apiKey", "agentId", "signingSecret"]
  }
}
